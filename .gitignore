# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# Claude AI assistant — local state (settings.local.json, projects/, etc.)
# stays out of the repo. Claude Code distribution now goes through the
# .claude-plugin manifest; this repo does not commit .claude/skills symlinks.
.claude/*

# agents.md-compatible tools can still use the CLI installer; no bootstrap
# symlinks are committed in this repo for now.
.agents/*

# Legacy install manifest. Older clones of lfx-skills wrote this; the CLI
# stores its manifest at ~/.lfx-skills/config.json, so this file is no
# longer used. Ignored in case any clone still has one lying around.
.install-manifest.json

# Environment and configuration files
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
.cache/

# Backup files
*.bak
*.backup
*.old

# Log files
*.log
logs/

# Lint reports
megalinter-reports/

# Superpowers specs and plans (local only)
docs/superpowers/
